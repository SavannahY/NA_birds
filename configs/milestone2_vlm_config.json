{
  "dataset_root": "nabirds",
  "output_dir": "reports/milestone2",
  "seed": 231,
  "num_classes": 555,
  "validation": {
    "source": "official_train_split_only",
    "strategy": "stratified",
    "val_fraction": 0.15
  },
  "preprocessing": {
    "image_size": 224,
    "higher_resolution_image_size": 384,
    "convert_rgb": true,
    "clip_bounding_boxes": true,
    "imagenet_mean": [0.485, 0.456, 0.406],
    "imagenet_std": [0.229, 0.224, 0.225]
  },
  "vlm_models": {
    "main_zero_shot": "google/siglip2-base-patch16-224",
    "fallback_zero_shot": "google/siglip-base-patch16-224",
    "prompted_vlm_candidates": [
      "Qwen/Qwen2.5-VL-7B-Instruct",
      "OpenGVLab/InternVL3-8B-Instruct"
    ]
  },
  "visual_baselines": {
    "sanity": ["random", "majority_class"],
    "weak_trainable": "resnet18_from_scratch",
    "main": "resnet50_imagenet",
    "strong": ["convnext_tiny_imagenet", "vit_b_16_imagenet"]
  },
  "experiments": [
    {
      "name": "full_image_baseline",
      "input": "full_image",
      "model": "resnet50_imagenet",
      "purpose": "main visual-only baseline"
    },
    {
      "name": "bbox_crop_baseline",
      "input": "clipped_bbox_crop",
      "model": "resnet50_imagenet",
      "purpose": "localization comparison"
    },
    {
      "name": "zero_shot_siglip2",
      "input": "full_image",
      "model": "google/siglip2-base-patch16-224",
      "purpose": "open-source VLM zero-shot baseline"
    },
    {
      "name": "fused_full_plus_crop",
      "input": "full_image_and_clipped_bbox_crop",
      "model": "shared_or_dual_backbone",
      "purpose": "proposed localization-aware method"
    }
  ],
  "metrics": [
    "top1_accuracy",
    "top5_accuracy",
    "macro_f1",
    "balanced_accuracy",
    "per_class_recall",
    "confusion_matrix"
  ]
}
